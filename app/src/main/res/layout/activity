<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <Button
        android:id="@+id/btnSelectPdf"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="选择PDF文件" />

    <RadioGroup
        android:id="@+id/rgSplitType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <RadioButton
            android:id="@+id/rbVertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="竖直分割（左右）"
            android:checked="true"/>

        <RadioButton
            android:id="@+id/rbHorizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="横向分割（上下）"/>
    </RadioGroup>

    <Button
        android:id="@+id/btnSplit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="开始分割并导出"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="状态：等待选择PDF"/>

</LinearLayout>
